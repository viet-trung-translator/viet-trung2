# --- along 翻译 environment variables ---

# Server
PORT=8080
NODE_ENV=development

# Auth — generate a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret

# Database (Neon PostgreSQL connection string)
# e.g. postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Google Gemini Live (speech-to-speech translation)
GEMINI_API_KEY=
# Live translate model id (configurable). Spec default:
GEMINI_MODEL=gemini-3.5-live-translate-preview

# Comma-separated origins allowed in production (optional). Empty = same-origin only.
CORS_ORIGINS=
